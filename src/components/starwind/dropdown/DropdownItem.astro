---
import type { ComponentProps, HTMLTag, Polymorphic } from "astro/types";
import { tv } from "tailwind-variants";

interface Props {
  /**
   * Whether the item is inset (has left padding)
   */
  inset?: boolean;
  /**
   * Whether the item is disabled
   */
  disabled?: boolean;

  class?: string;

  as: HTMLTag;

  rest: Polymorphic<typeof Tag> | ComponentProps<typeof Tag>;
};

export const dropdownItem = tv({
  base: [
    "relative flex items-center px-(--sp-2xs) py-(--sp-3xs)",
    "transition-colors focus-visible:bg-accent focus-visible:text-accent-foreground",
    "cursor-default outline-none select-none",
    "data-[disabled]:pointer-events-none data-[disabled]:opacity-50"
  ],
  variants: {
    inset: {
      true: "pl-(--sp-md)",
    },
    disabled: {
      true: "pointer-events-none opacity-50",
    },
  },
  defaultVariants: {
    inset: false,
    disabled: false,
  },
});

const { class: className, inset = false, disabled = false, as: Tag = "li", ...rest } = Astro.props;
---

<Tag
  class={dropdownItem({ inset, disabled, class: className })}
  data-disabled={disabled ? "true" : undefined}
  data-slot="dropdown-item"
  tabindex="-1"
  {...rest}
>
  <slot />
</Tag>
