---
import { twMerge } from 'tailwind-merge'
import { type HTMLAttributes } from "astro/types";
import { Button, Spinner } from '@/components/base';

export interface Props extends HTMLAttributes<"div"> {
  labelId: string,
};

const {
  labelId,
  class: className,
  ...rest
} = Astro.props;

---

<div class={twMerge(
  "w-86 h-94 flex items-top has-[.base-gl-active]:items-center justify-center",
  // Wait a little while before showing the element (prevents flashes as JS gets things set up)
  "transition-discrete transition-opacity delay-350 duration-150",
  "starting:invisible visible starting:opacity-0 opacity-100",
  className
  )}
  {...rest}
>
  {/* Button visible by default, to handle case where JS is disabled entirely. */}
  <Button class="base-gl-button text-xl"
    icon="local:donate"
    iconClass="w-full h-auto"
    alt="Donate Online with Give Lively"
    href="https://secure.givelively.org/donate/christians-concerned-for-the-community-inc"
    variant="ghost"
    animation="raise"
  />
  <Spinner class="base-gl-spinner size-2xl text-foreground"
    hidden
  />
  <div id="give-lively-widget" class="gl-simple-donation-widget"
    hidden role="form" aria-labelledby={labelId}
  />
</div>

{/* Give Lively Fundraising Widget, URL of script to embed was obtained from here:
    https://secure.givelively.org/nonprofits/christians-concerned-for-the-community-inc/simple-donation-widget
*/}
<script>
{
  const buttons = document.querySelectorAll(".base-gl-button");
  const spinners = document.querySelectorAll(".base-gl-spinner");
  const widgets = document.querySelectorAll(".gl-simple-donation-widget");

  const toggleHidden = (list: NodeListOf<Element>, force: boolean) => {
    list.forEach((el) => {el.toggleAttribute("hidden", force)});
  };

  // Hide donate button, show spinner.
  toggleHidden(buttons, true);
  toggleHidden(spinners, false);

  const gl=document.createElement('script');
  gl.src='https://secure.givelively.org/widgets/simple_donation/christians-concerned-for-the-community-inc.js?show_suggested_amount_buttons=true&show_in_honor_of=false&address_required=false&has_required_custom_question=false&suggested_donation_amounts[]=25&suggested_donation_amounts[]=50&suggested_donation_amounts[]=100&suggested_donation_amounts[]=250';

  gl.onload = () => {
    // Success: hide spinner, show donation widget, apply class to advertise that widget is active.
    toggleHidden(spinners, true);
    // Apply a class to the widget that advertises the widget is active.
    widgets.forEach((el) => {
      el.toggleAttribute("hidden", false);
      el.classList.toggle("base-gl-active", true);
    });
  };

  gl.onerror = () => {
    // Failure: hide spinner, show donate button.
    toggleHidden(spinners, true);
    toggleHidden(buttons, false);
  };

  document.head.appendChild(gl);
}
</script>