---
import { twMerge } from 'tailwind-merge'
import { type HTMLAttributes } from "astro/types";
import { Spinner } from '@/components/base';

export interface Props extends HTMLAttributes<"div"> {
  labelId: string,
};

const {
  labelId,
  class: className,
  ...rest
} = Astro.props;

const classDefault = [
  "w-cw-xs h-cw-sm flex items-center justify-center"
];
---

<div class={twMerge(classDefault, className)} {...rest}>
  <Spinner class="base-gl-spinner m-auto size-2xl text-foreground"/>
  <div id="give-lively-widget" class="gl-simple-donation-widget"
    hidden role="form" aria-labelledby={labelId}
  />
</div>

{/* Give Lively Fundraising Widget, embed code was obtained from here:
    https://secure.givelively.org/nonprofits/christians-concerned-for-the-community-inc/simple-donation-widget
*/}
<script>
{
  const gl=document.createElement('script');
  gl.src='https://secure.givelively.org/widgets/simple_donation/christians-concerned-for-the-community-inc.js?show_suggested_amount_buttons=true&show_in_honor_of=false&address_required=false&has_required_custom_question=false&suggested_donation_amounts[]=25&suggested_donation_amounts[]=50&suggested_donation_amounts[]=100&suggested_donation_amounts[]=250';

  // BEGIN: stuff I added to disable the spinner when the script is done
  gl.onload = () => {
    document.querySelectorAll(".base-gl-spinner").forEach((el) => {
      el.toggleAttribute("hidden", true);
    });

    document.querySelectorAll(".gl-simple-donation-widget").forEach((el) => {
      el.toggleAttribute("hidden", false);
    })
  };
  // END: stuff I added

  document.head.appendChild(gl);
}
</script>