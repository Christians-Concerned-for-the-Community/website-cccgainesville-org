---
import { twMerge } from 'tailwind-merge'
import { type HTMLAttributes } from "astro/types";
import { Button, Icon, Spinner } from '@/components/base';

export interface Props extends HTMLAttributes<"div"> {
  labelId: string,
};

const {
  labelId,
  class: className,
  ...rest
} = Astro.props;

---

<div data-state="initial" class={twMerge("base-gl-container group",
  "flex grow items-center justify-center",
  "min-w-76 w-full max-w-86 h-94 p-1 3xs:p-2xs 2xs:p-sm",
  className
  )}
  {...rest}
>
  {/* Only show button and error message on error, or if javascript is disabled. */}
  <div class:list={[
    "hidden not-js:flex group-data-[state=error]:flex flex-col gap-md px-xs",
    // Wait a little while before showing the element (prevents flashes as JS gets things set up)
    "transition-opacity delay-200 duration-0",
    "starting:opacity-0 opacity-100",
  ]}>
    <div class="flex items-center justify-center gap-xs mx-xs">
      <Icon name="tabler:alert-triangle" size="4em" class="text-warning"/>
      <p class="text-justify">Could not load donation form. To donate, click the button below.</p>
    </div>
    <Button class="text-xl w-auto h-auto"
      icon="local:donate"
      iconClass="w-full h-auto"
      alt="Donate to CCC at Give Lively"
      href="https://secure.givelively.org/donate/christians-concerned-for-the-community-inc"
      variant="ghost"
      animation="raise"
    />
  </div>
  <Spinner
    class="hidden js:group-data-[state=initial]:block size-2xl text-foreground"
    hidden
  />
  <div id="give-lively-widget" role="form" aria-labelledby={labelId}
    class="gl-simple-donation-widget hidden js:group-data-[state=ok]:block"
  />
</div>

{/* Give Lively Fundraising Widget, URL of script to embed was obtained from here:
    https://secure.givelively.org/nonprofits/christians-concerned-for-the-community-inc/simple-donation-widget
*/}
<script>
{
  const containers = document.querySelectorAll<HTMLElement>(".base-gl-container");
  const setState = (state: 'error' | 'ok') => {
    containers.forEach((el) => {el.dataset.state = state});
  };

  const gl=document.createElement('script');
  gl.src='https://secure.givelively.org/widgets/simple_donation/christians-concerned-for-the-community-inc.js?show_suggested_amount_buttons=true&show_in_honor_of=false&address_required=false&has_required_custom_question=false&suggested_donation_amounts[]=25&suggested_donation_amounts[]=50&suggested_donation_amounts[]=100&suggested_donation_amounts[]=250';

  // Initial state: show spinner (if javascript enabled).

  // Success: show donation widget.
  gl.onload = () => { setState('ok') };

  // Failure: show donate button.
  gl.onerror = () => { setState('error'); };

  document.head.appendChild(gl);
}
</script>