---
import Facebook from "@/assets/icons/facebook.svg"
import Instagram from "@/assets/icons/instagram.svg"
import Menu from "@icons/menu-2.svg"
import ChevronDown from "@icons/chevron-down.svg"

import Logo from "@/components/Logo.astro"
import Link from "@/components/Link.astro"
import { Dropdown, DropdownTrigger, DropdownContent, DropdownItem } from "@/components/starwind/dropdown";
import { Button } from "@/components/starwind/button";
import { ThemeToggle } from "@/components/starwind/theme-toggle";
import { Sheet, SheetClose, SheetContent, SheetFooter, SheetTrigger, } from "@/components/starwind/sheet";


/**
 * Header Component
 *
 * @description A component that displays the logo and navbar of the website
 */

const maxItems = 5;

const items = [
  { label: "Services",
    href:  "/services/",
  },
  { label: "Give",
    href:  "/give/",
  },
  { label: "Volunteer",
    href:  "/volunteer/",
  },
  { label: "Contact",
    href:  "/contact/",
  },
  { label: "News",
    href:  "/news/"
  },
  { label: "Our Values",
    href:  "/our-values/"
  },
  { label: "Documents",
    href:  "/documents/"
  },
];

const icons = [
  { icon: Facebook,
    href: "https://facebook.com/cccgainesville",
    alt:  "Go to our Facebook page",
  },
  { icon: Instagram,
    href: "https://instagram.com/cccmainoffice",
    alt:  "Go to our Instagram page",
  },
];

const doDropdown = (items.length > maxItems);
const split = doDropdown? maxItems - 1 : items.length;
---

<header class="max-fullnav:sticky max-fullnav:top-0 max-fullnav:z-50 px-(--sp-sm) py-(--sp-md) bg-background/80 backdrop-blur-lg shadow-sm">
  
  {/* Skip Link (visually hidden but accessible via keyboard focus) */}
  <a href="#main-content" class:list={[ "py-(--sp-sm) px-(--sp-lg) rounded-lg",
      "sr-only focus:not-sr-only focus:absolute focus:top-0 focus:left-0",
      "focus:z-50 focus:p-(--sp-sm) focus:bg-wb focus:text-bw"]} >
    Skip to main content
  </a>

  <div class="max-w-(--content-max) h-(--sp-2xl) mx-auto px-(--sp-sm-md) flex flex-wrap justify-between items-center">
    
    {/* Logo / Home Link */}
    <div class="flex shrink-0 items-center">
      <Logo/>
    </div>

    
    <nav class="">
      {/* Full menu: visible when width >= fullnav */}
      <ul class="space-x-(--sp-xs) hidden fullnav:flex
        [&_li]:flex [&_li]:items-center">
      
      { /* Main text links along the top. */
        items.slice(0,split).map((item) => (
        <li>
          <Link href={item.href}
            class="text-md py-(--sp-2xs) px-(--sp-3xs) underline-offset-3 hover:underline"
            thisPageClass="underline"
          >
            {item.label}
          </Link>
        </li>
      ))}

      { /* Add additional links in a dropdown menu, if necessary. */
        doDropdown && (
          <li class="ml-(--sp-2xs)">
            <Dropdown>
              <DropdownTrigger asChild>
                <Button variant="outline" class="aria-expanded:[&_svg]:-scale-y-100">
                  More
                  <ChevronDown />
                </Button>
              </DropdownTrigger>
              <DropdownContent align="end" class="p-(--sp-xs) --space-y-(--sp-xs)">

              {items.slice(split).map((item) => (
                <DropdownItem>
                  <Link
                    href={item.href}
                    class="text-md underline-offset-3 hover:underline"
                    thisPageClass="underline"
                  >
                    {item.label}
                  </Link>
                </DropdownItem>
              ))}
              
              </DropdownContent>
            </Dropdown>
          </li>
        )
      }

      { /* Add social icons to the icon tray. */
        icons.map( (item) => {
          const Icon = item.icon;
          return (
          <li class="flex shrink-0 items-center">
            <Link href={item.href} aria-label={item.alt}>
              <Icon />
            </Link>
          </li>
          );
        })
      }

      {/* Add dark mode toggle to the icon tray. */}
        <li class="flex shrink-0 items-center">
          <ThemeToggle ariaLabel="Toggle dark mode"/>
        </li>
      </ul>

      {/* Menu button: visible when width < fullnav */}
      <div class="flex fullnav:hidden shrink-0 items-center">
        <SheetTrigger asChild for="mobile-nav">
          <Button>
            Menu
            <Menu aria-hidden="true"/>
          </Button>
        </SheetTrigger>
      </div>

      <Sheet id="mobile-nav">
        <SheetContent side="right" class="pt-(--sp-md)">
          <ul class="flex flex-col gap-(--sp-md)">
            {items.map((item) => (
            <li>
              <Link href={item.href}
                class="text-lg underline-offset-3 hover:underline"
                thisPageClass="underline"
              >
                {item.label}
              </Link>
            </li>
            ))}
            <div class="flex flex-row justify-center items-center mx-(--sp-md)">
              {/* Add social icons to the icon tray. */
              icons.map( (item) => {
                const Icon = item.icon;
                return (
                <div class="flex shrink-0 items-center">
                  <Link href={item.href} aria-label={item.alt}>
                    <Icon />
                  </Link>
                </div>
                );
              })}
              {/* Add dark mode toggle to the icon tray. */}
              <li class="flex shrink-0 items-center">
                <ThemeToggle ariaLabel="Toggle dark mode"/>
              </li>
            </div>
          </ul>
          <SheetFooter>
            <SheetClose asChild>
              <Button>Close</Button>
            </SheetClose>
          </SheetFooter>
        </SheetContent>
      </Sheet>
    </nav>
  </div>
</header>
