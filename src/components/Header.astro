---
import { Icon } from 'astro-icon/components'
import { Nav, type NavLink, type NavIcon } from "@/components/base"

export interface NavData {
  maxVisibleLinks?: number,
  darkModeToggle?: boolean,
  disclosureLabel?: string,
  links: NavLink[],
  icons?: NavIcon[],
}

const nav: NavData = {
  maxVisibleLinks: 5,
  darkModeToggle: true,
  disclosureLabel: "More",
  links: [
    { label: "Home",
      href: "/",
    },
    { label: "Services",
      href:  "/services/",
    },
    { label: "Give",
      href:  "/give/",
    },
    { label: "Contact",
      href:  "/contact/",
    },
    { label: "Volunteer",
      href:  "/volunteer/",
    },
    { label: "News",
      href:  "/news/"
    },
    { label: "Our Values",
      href:  "/our-values/"
    },
    { label: "Documents",
      href:  "/documents/"
    },
  ],
  icons: [
    { file: 'facebook',
      href: "https://facebook.com/cccgainesville",
      alt:  "Go to our Facebook page",
      excludeFromFull: true
    },
    { file: 'instagram',
      href: "https://instagram.com/cccmainoffice",
      alt:  "Go to our Instagram page",
      excludeFromFull: true
    },
  ]
}


---
<header class:list={[
  "text-md py-md bg-background/80 backdrop-blur-lg",
  /* Make the header sticky on mobile: */
  "max-sm:sticky max-sm:shadow-md max-sm:top-0 max-sm:z-50"
]}>
  
  {/* Skip Link (hidden, but becomes visible when focused by pressing "tab" key) */}
  <a href="#main-content" class:list={[
      "sr-only focus-visible:not-sr-only",
      "focus-visible:bg-wb focus-visible:text-bw",
      "focus-visible:absolute focus-visible:top-sm focus-visible:left-sm",
      "focus-visible:z-50 focus-visible:p-sm"]} >
    Skip to main content
  </a>

  {/* Navigation bar on wide screens, disappearing side nav panel on narrow screens. */}
  <Nav links={nav.links} icons={nav.icons} maxVisibleLinks={nav.maxVisibleLinks}>
    {/* Logo / Home Link */}
    <a href="/" class:list={["p-1 hover:bg-muted active:bg-muted-dark",
      "duration-200 transition-[background-color]"
    ]}>
      <Icon name="ccc-logo-wide" aria-hidden="true" width="100%" height="100%"
        class="block aspect-488/120 text-foreground"
      />
      <span class="sr-only">Christians Concerned for the Community</span>
    </a>
  </Nav>
</header>