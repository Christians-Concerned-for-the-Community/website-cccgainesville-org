---
import { Button } from '@/components/starwind/button'

/**
 * CallToAction Component
 *
 * @description A prominent call-to-action section with a title and link
 */
interface Props {
  /**
   * The title text to display
   */
  title: string
  /**
   * The URL the button should link to
   */
  href: string
}

const {
  title,
  href,
} = Astro.props
---

<section class={"flex flex-col items-center gap-(--sp-xl) rounded-xl"
  + " my-(--sp-3xl) py-(--sp-xl) px-(--sp-sm) md:px-(--sp-2xl) text-neutral-900"
  + " bg-linear-315 from-theme-grad3 from-25% to-theme-grad4"
}>
  <div class="px-(--sp-sm) md:px-(--sp-2xl)">
    <h2 class="text-center text-3xl md:text-6xl">{title}</h2>
    <Button href={href} variant="primary" size="lg" animation="raise-boop">
      <slot />
    </Button>
  </div>
</section>