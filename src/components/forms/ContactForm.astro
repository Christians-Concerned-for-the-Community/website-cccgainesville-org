---
import {Form, FormField} from '@/components/base';
import { defineAction } from 'astro:actions';
import { z } from 'astro/zod';
import { zc } from "./zod-common.ts"

export const handleForm = defineAction({
  accept: 'form',
  input: z.object({
    name: zc.full_name,
    email: zc.email,
    phone: zc.us_phone,
    message: z
      .string("Type in your message to us.")
      .max(1500, "Message is too long, max is 1500 characters.")
  }),
  handler: async ({ name, email, phone, message}) => {
    /* TODO: implement this method */
    console.log(`Name: ${name}`);
    console.log(`Email: ${email}`);
    console.log(`Phone: ${phone}`);
    console.log(`Message:\n----\n${message}\n----`);
  },
});

---

<Form turnstileKey="" handlerAction="handleContactForm"
  submitButton={{
    label:"Send Message"
  }}
>
  <FormField type="full-name" name="name"    required label="Name" />
  <FormField type="email"     name="email"   required label="Email" />
  <FormField type="tel"       name="phone"   required label="Phone" />
  <FormField type="textarea"  name="message" required label="Message" />
</Form>
