---
/**
 * Wrapper that lets you import icons from various icon libraries (or locally)
 * using a name string.
 */

import type { HTMLAttributes } from "astro/types";
import { twMerge } from "tailwind-merge";

import ErrorIcon from "./assets/file-unknown.svg"
import { iconMap } from "./assets/icons.ts"; // manually run icons-generator.ts in root dir to generate this file


interface Props extends Omit< HTMLAttributes<"svg">, "aria-hidden" > {
  /**
   * Name of the icon to use.
   * 
   * If you're using a library, add it as a prefix with ':'.
   * 
   * If no prefix was added, icons will be searched for in src/assets/icons.
   * 
   * Supported libraries:
   *   - local: same as having no prefix
   *   - tabler: requires @tabler/icons package, pulls from "outline" dir
   *   - tabler-filled: requires @tabler/icons package, pulls from "filled" dir
   * 
   * (the .svg extension will be added automatically)
   */
  name: string,

  /**
   * For convenience - sets both width and height to same value.
   */
  size?: string,
}

const {
  size,
  name,
  class: className,
  ...rest
} = Astro.props;

let sizeAttrs: Record<string,string> = {};
if (size) {
  sizeAttrs.width = size;
  sizeAttrs.height = size;
}

const icon = iconMap.get(name.includes(":")? name : "local:"+name);
const IconComponent = icon ?? ErrorIcon;

if (!icon) {
  console.warn(`[base/Icon]: Icon "${name}" not found.`);
}
---

<IconComponent class={twMerge("inline", className)}
 aria-hidden="true" {...sizeAttrs} {...rest}
/>