---
import { Link } from 'accessible-astro-components'
import { Image } from 'astro:assets'
import logo_light from '@assets/logo-wide-light.svg'
import logo_dark from '@assets/logo-wide-dark.svg'

---

<Link href="/" class="flex items-center -ml-6">
  <Image
    src={logo_light}
    alt="CCC Logo"
    priority={true}
    class="block dark:hidden w-54 min-[33.75rem]:w-76 h-full"
  />
  <Image
    src={logo_dark}
    alt="CCC Logo"
    priority={true}
    class="hidden dark:block w-54 min-[33.75rem]:w-76 h-full"
  />
</Link>
