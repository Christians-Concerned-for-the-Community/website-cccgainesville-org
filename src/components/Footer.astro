---
import PageSection from '@components/PageSection.astro'
import { Heading, Link } from 'accessible-astro-components'

/**
 * Footer Component
 *
 * @description A component that displays the footer of the website
 */
const currentYear = new Date().getFullYear()
---

<footer id="footer" class="py-8 border-t border-theme-subtle">
  <PageSection>
    <Heading level="h2" class="sr-only">Footer</Heading>
    <div class="flex flex-col gap-4 md:flex-row md:justify-between">
      <p>
        &copy; {currentYear} - Christians Concerned for the Community
      </p>
      <p>
        Made with ❤️ by <Link href="https://github.com/stephen-sorley">Stephen Sorley</Link>.
      </p>
    </div>
  </PageSection>
</footer>