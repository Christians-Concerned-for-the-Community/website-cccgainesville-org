---
import type { ImageMetadata } from 'astro';
import type { ComponentProps } from 'astro/types';

import BaseLayout from '@/layouts/BaseLayout.astro'
import PageHeading from '@/components/PageHeading.astro'


/**
 * PageLayout Component
 *
 * @description layout for standard pages on the website - includes the full
 *              nav bar, title/subtitle and featured image header, and wraps
 *              the main content in a styled container.
 */
export interface Props extends ComponentProps<typeof BaseLayout> {
  /**
   * The subtitle of the page (optional)
   */
  subtitle?: string

  /**
   * The featured image of the page (optional)
   * 
   * Recommended aspect ratio: 3 x 2
   */
  featuredImage?: ImageMetadata

  /**
   * The width of the section.
   *   normal: 300rem (1200px) max
   *   narrow: 200rem (800px) max
   *   stretch: full viewport width (retains some padding)
   * @type {'normal' | 'narrow' | 'stretch' | undefined}
   * @default normal
   */
  width?: 'normal' | 'narrow' | 'stretch'

  /**
   * Include a page header?
   * @default true
   */
  showHeading?: boolean

  /**
   * HTML attributes
   */
  [key: string]: any
}

const {
  class: className,
  title,
  subtitle,
  featuredImage,
  width = 'normal',
  showHeading = true,
  ...rest
} = Astro.props

let classWidth = "";
switch(width) {
  case 'normal':  classWidth = "max-w-(--content-max)"; break;
  case 'narrow':  classWidth = "max-w-(--content-narrow)"; break;
  case 'stretch': classWidth = "max-w-full"; break;
}
---

<BaseLayout title={title} {...rest}>
  {showHeading && (
    <PageHeading id="page-heading" title={title} subtitle={subtitle} featuredImage={featuredImage} />
  )}
  <div id="after-heading" class:list={["mx-auto px-sm-md my-xl-2xl", classWidth, className]}>
    <slot />
  </div>
</BaseLayout>