---
import '@/styles/globals.css'
import type { HTMLAttributes } from 'astro/types'
import { SiteMeta } from '@/components/base'
import Header from '@/components/Header.astro'
import Footer from '@/components/Footer.astro'

// Used for preloading.
const fontPath = "/fonts/AtkinsonHyperlegibleNext-VariableFont_wght.woff2";

/**
 * BaseLayout Component
 *
 * @description contains common code for every page on the website
 */
interface Props extends HTMLAttributes<"main"> {
  /**
   * The title of the page
   */
  title?: string,
  
  /**
   * Site / page description (used in site metadata tags)
   */
  description?: string,

  /**
   * Author of page (used in site metadata tags).
   */
  author?: string,

  /**
   * Always hide this page from search engines, even on production builds.
   * @default false
   */
  alwaysHide?: boolean
}

const {
  title = 'Christians Concerned for the Community',
  description = 'CCC is a Christian charity based in Gainesville, FL that provides used furniture and builds wheelchair ramps for our neighbors in Alachua County.',
  author = 'Christians Concerned for the Community',
  alwaysHide = false,
  class: className,
} = Astro.props
---

<html lang="en" dir="ltr" class="min-h-dvh">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta http-equiv="X-UA-Compatible" content="ie=edge" />

    <!-- for staging builds, or pages that pass alwaysHide=true, tell search engine bots not to index this page (even if crawled) -->
    {(Astro.site?.hostname.startsWith("staging") || alwaysHide) &&
      <meta name="robots" content="noindex, nofollow">
    }

    <!-- preload our main font, so that it's not chained after the main CSS file -->
    <link rel="preload" as="font" type="font/woff2" href={fontPath} crossorigin="anonymous" />
    <!-- favicon stuff -->
    <!-- https://dev.to/masakudamatsu/favicon-nightmare-how-to-maintain-sanity-3al7 -->
    <link rel="icon" href="/favicon.ico" sizes="48x48" >
    <link rel="icon" href="/favicon.svg" sizes="any" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/apple-touch-icon.png"/>
    <link rel="manifest" href="/site.webmanifest" crossorigin="use-credentials"/>
    
    <!-- sitemap hint -->
    <link rel="sitemap" href="/sitemap-index.xml" />

    <SiteMeta
      title={title}
      description={description}
      url={Astro.site?.toString() || "cccgainesville.org"}
      image='social-preview.png'
      author={author}
    />

    {/*
      Script that applies the dark mode settings on page load.

      See: src/components/starwind/theme-toggle/ThemeToggle.astro
    */}
    <script>
      const initTheme = () => {
        const colorTheme = localStorage.getItem("colorTheme");
        document.documentElement.classList.toggle("dark",
          colorTheme?
            colorTheme==="dark"
            :
            window.matchMedia("(prefers-color-scheme: dark)").matches
        );
      }
      initTheme();
      document.addEventListener("astro:after-swap", initTheme);
    </script>

  </head>
  <body class="min-h-dvh flex flex-col overflow-x-clip">
    <Header />
    <main id="main-content" class:list={["grow shrink-0 basis-auto", className]}>
      <slot />
    </main>
    <Footer class="shrink-0" />
  </body>
</html>