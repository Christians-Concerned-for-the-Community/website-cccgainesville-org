# Server-side redirects (will be handled by Cloudflare for us)
# See: https://developers.cloudflare.com/workers/static-assets/redirects/
#
# Format:
#  [source] [destination] [code?]
#
# where:
#    source: original path, can include wildcards & placeholders
#    destination: path to redirect to instead (either relative, or an external path)
#    code: HTTP status code to use for redirect (optional, default is 302)
#          301- permanent redirect
#          302- temporary redirect
#
# Example:
#    /donate /give
#    Any requests for https://[this site]/donate will be redirected to https://[this site]/give.

# Map routes from the old Wordpress site to our new one.
/donate     /give             301
/contact-us /contact          301
/about      /about/our-values 301
/volunteer  /about/volunteer  301
/news       /about/news       301
/about/docs /about/documents  301

