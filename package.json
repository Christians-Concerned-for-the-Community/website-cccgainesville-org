{
  "name": "website-cccgainesville-org",
  "description": "Main website for Christians Concerned for the Community",
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "CLOUDFLARE_ENV=development astro dev",
    "build": "wrangler types && astro check && astro build",
    "preview": "CLOUDFLARE_ENV=development sh -c 'wrangler types && astro check && astro build && astro preview'",
    "astro": "astro",
    "deploy": "wrangler deploy --env=''",
    "deploy-production": "wrangler deploy --env='production'",
    "generate-types": "wrangler types"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.6.0",
    "@typescript-eslint/eslint-plugin": "^8.59.0",
    "@typescript-eslint/parser": "^8.59.0",
    "eslint": "^10.2.1",
    "eslint-plugin-astro": "^1.7.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "globals": "^17.5.0"
  },
  "dependencies": {
    "@astrojs/check": "^0.9.8",
    "@astrojs/cloudflare": "^13.2.0",
    "@astrojs/sitemap": "^3.7.2",
    "@tabler/icons": "^3.41.1",
    "@tailwindcss/vite": "^4.2.4",
    "astro": "^6.1.9",
    "sharp": "^0.34.5",
    "tailwind-merge": "^3.5.0",
    "tailwind-variants": "^3.2.2",
    "tailwindcss": "^4.2.4",
    "tw-animate-css": "^1.4.0",
    "wrangler": "^4.84.1"
  }
}
