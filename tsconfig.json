{
  "extends": "astro/tsconfigs/strict",
  "compilerOptions": {
    "baseUrl": ".",
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "paths": {
      "@public/*": [
        "public/*"
      ],
      "@/*": [
        "src/*"
      ],
      "@icons/*": [
        "node_modules/@tabler/icons/icons/outline"
      ],
      "@icons-filled/*": [
        "node_modules/@tabler/icons/icons/filled"
      ]
    }
  }
}
