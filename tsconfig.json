{
  "extends": "astro/tsconfigs/strict",
  "include": [
    ".astro/types.d.ts",
    "./worker-configuration.d.ts",
    "**/*",
  ],
  "exclude": [
    "dist",
    ".git",
    ".vscode",
    ".wrangler",
  ],
  "compilerOptions": {
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "verbatimModuleSyntax": true,
    "paths": {
      "@/*": ["./src/*"],
      "@public/*": ["./public/*"],
    }
  }
}